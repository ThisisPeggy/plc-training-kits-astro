---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { products } from '../../../data/products';
import { locales, type Lang } from '../../../i18n/config';
import { t, getLocalizedPath } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.flatMap((lang) =>
    products.map((product) => ({
      params: { lang, slug: product.slug },
      props: { lang, product },
    }))
  );
}

const { lang, product } = Astro.props as { lang: Lang; product: typeof products[0] };
const related = products.filter((p) => p.category === product.category && p.slug !== product.slug).slice(0, 3);
const siteUrl = 'https://plc-training-kits.tech';

const schemaOrg = [
  {
    '@context': 'https://schema.org/',
    '@type': 'Product',
    name: product.name,
    description: product.description,
    image: `${siteUrl}${encodeURI(product.image)}`,
    sku: product.sku,
    brand: { '@type': 'Brand', name: product.brand },
    manufacturer: { '@type': 'Organization', name: 'Kernal Automation' },
    offers: {
      '@type': 'Offer',
      url: `${siteUrl}/${lang}/products/${product.slug}/`,
      priceCurrency: 'USD',
      price: String(product.priceValue),
      priceValidUntil: '2026-12-31',
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      seller: { '@type': 'Organization', name: 'Kernal Automation' },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t(lang, 'product.home'), item: `${siteUrl}/${lang}/` },
      { '@type': 'ListItem', position: 2, name: t(lang, 'nav.trainingKits'), item: `${siteUrl}/${lang}/#products` },
      { '@type': 'ListItem', position: 3, name: product.shortName, item: `${siteUrl}/${lang}/products/${product.slug}/` },
    ],
  },
];
---

<BaseLayout
  lang={lang}
  title={`${product.name} | PLC Training Kits`}
  description={product.description}
  image={product.image}
  canonicalPath={`/${lang}/products/${product.slug}/`}
  schemaJsonLd={schemaOrg}
>
  <section class="product-page">
    <div class="container">
      <div class="breadcrumb">
        <a href={getLocalizedPath(lang)}>{t(lang, 'product.home')}</a> /
        <a href={`${getLocalizedPath(lang)}#products`}>{t(lang, 'nav.trainingKits')}</a> /
        <span>{product.shortName}</span>
      </div>

      <div class="product-shell">
        <div class="product-column">
          <div class="product-panel product-media">
            <img src={product.image} alt={product.name} />
          </div>
          <div class="product-panel product-summary">
            <div class="product-summary__row">
              <span>{t(lang, 'product.brand')}</span>
              <strong>{product.brand}</strong>
            </div>
            <div class="product-summary__row">
              <span>{t(lang, 'product.series')}</span>
              <strong>{product.series}</strong>
            </div>
            <div class="product-summary__row">
              <span>SKU</span>
              <strong>{product.sku}</strong>
            </div>
            <div class="product-summary__row">
              <span>{t(lang, 'product.price')}</span>
              <strong>{product.priceLabel}</strong>
            </div>
          </div>
        </div>

        <div class="product-panel product-copy">
          <span class="tag">{product.brand}</span>
          <h1>{product.name}</h1>
          <p class="product-kicker">{product.intro}</p>
          <div class="product-meta">
            <div class="price">{product.priceLabel}</div>
            <span class="product-meta__series">{product.series}</span>
          </div>
          <p>{product.description}</p>
          <ul class="feature-list">
            {product.features.map((f) => <li>{f}</li>)}
          </ul>
          <div class="product-actions">
            <a class="button button--primary" href={`https://wa.me/8617612051841?text=${encodeURIComponent(`Hi Peggy, I'm interested in the ${product.name}.`)}`} target="_blank">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              {t(lang, 'product.whatsapp')}
            </a>
            <a class="button button--secondary" href={`${getLocalizedPath(lang)}#products`}>{t(lang, 'product.backToCatalog')}</a>
          </div>
        </div>
      </div>

      {related.length > 0 && (
        <div class="section">
          <div class="section-header">
            <h2 class="section-title">{t(lang, 'product.related')}</h2>
            <p class="section-subtitle">{t(lang, 'product.relatedDesc')}</p>
          </div>
          <div class="related-grid">
            {related.map((item) => (
              <a class="related-card" href={`/${lang}/products/${item.slug}/`}>
                <span class="tag">{item.series}</span>
                <h3>{item.shortName}</h3>
                <p style="color:var(--text-light);font-size:0.92rem;margin:0 0 0.5rem;">{item.intro}</p>
                <div class="card__footer">
                  <div class="price">{item.priceLabel}</div>
                  <span class="card__link">View &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
