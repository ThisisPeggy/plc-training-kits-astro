---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';
import { locales, type Lang } from '../../i18n/config';
import { t, getLocalizedPath } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props as { lang: Lang };

const siemensProducts = products.filter((p) => p.category === 'siemens');
const mitsubishiProducts = products.filter((p) => p.category === 'mitsubishi');
const abProducts = products.filter((p) => p.category === 'allen-bradley');
const cabinetProducts = products.filter((p) => p.category === 'control-cabinets');
const heroProduct = siemensProducts[0];

const siteUrl = 'https://plc-training-kits.tech';

const schemaOrg = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'PLC Training Kits',
    url: siteUrl,
    description: 'Professional PLC training kits with Siemens S7-1200, Mitsubishi FX5U, and Allen-Bradley Micro850.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: "Peggy's Automation Store",
    image: `${siteUrl}/logo.png`,
    telephone: '+86-176-1205-1841',
    email: 'peggy@kernal-automation.com',
    url: siteUrl,
    areaServed: 'Worldwide',
    priceRange: '$95-$2100',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'PLC Training Kits',
    url: `${siteUrl}/${lang}/#products`,
    numberOfItems: 15,
    itemListElement: products.filter((p) => p.category !== 'control-cabinets').map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteUrl}/${lang}/products/${p.slug}/`,
      name: p.name,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: (t(lang, 'faq.items') as any).map((item: any) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
];

const whyItems = t(lang, 'why.items') as any;
const faqItems = t(lang, 'faq.items') as any;
const testimonialItems = t(lang, 'testimonials.items') as any;
const processSteps = t(lang, 'process.steps') as any;
const svcPlcItems = t(lang, 'services.plc.items') as any;
const svcSoftItems = t(lang, 'services.software.items') as any;
const svcCustomItems = t(lang, 'services.custom.items') as any;
---

<BaseLayout
  lang={lang}
  title={`${t(lang, 'products.title')} | Siemens, Mitsubishi & Allen-Bradley`}
  description={t(lang, 'hero.desc')}
  canonicalPath={`/${lang}/`}
  schemaJsonLd={schemaOrg}
>
  <!-- Hero -->
  <section class="home-hero" id="overview">
    <div class="container home-hero__inner">
      <div>
        <span class="hero-badge">{t(lang, 'hero.badge')}</span>
        <h1>{t(lang, 'hero.title')}</h1>
        <p class="home-hero__desc">{t(lang, 'hero.desc')}</p>
        <div class="home-hero__actions">
          <a class="button button--primary" href={`https://wa.me/8617612051841?text=${encodeURIComponent("Hi Peggy, I'm looking for a PLC training kit for my school/organization. Can you share the catalog?")}`} target="_blank">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            {t(lang, 'hero.cta')}
          </a>
          <a class="button button--secondary" href="#products">{t(lang, 'nav.trainingKits')}</a>
        </div>
      </div>
      <div class="home-hero__image">
        <img src={heroProduct.image} alt={heroProduct.name} />
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat-box"><strong>20+</strong><span>{t(lang, 'stats.kits')}</span></div>
      <div class="stat-box"><strong>50+</strong><span>{t(lang, 'stats.countries')}</span></div>
      <div class="stat-box"><strong>100%</strong><span>{t(lang, 'stats.docs')}</span></div>
      <div class="stat-box"><strong>{t(lang, 'stats.warrantyVal')}</strong><span>{t(lang, 'stats.warranty')}</span></div>
    </div>
  </section>

  <!-- Products -->
  <section class="section products-section" id="products">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'products.title')}</h2>
        <p class="section-subtitle">{t(lang, 'products.subtitle')}</p>
      </div>

      <div class="cat-tabs" role="tablist">
        <button class="cat-tab siemens active" data-cat="siemens" role="tab" aria-selected="true">{t(lang, 'products.siemens')}</button>
        <button class="cat-tab mitsubishi" data-cat="mitsubishi" role="tab" aria-selected="false">{t(lang, 'products.mitsubishi')}</button>
        <button class="cat-tab ab" data-cat="ab" role="tab" aria-selected="false">{t(lang, 'products.ab')}</button>
      </div>

      {[
        { id: 'siemens', items: siemensProducts, brandClass: 'siemens' },
        { id: 'mitsubishi', items: mitsubishiProducts, brandClass: 'mitsubishi' },
        { id: 'ab', items: abProducts, brandClass: 'ab' },
      ].map(({ id, items, brandClass }, catIdx) => (
        <div class={`cat-content ${catIdx === 0 ? 'active' : ''}`} id={`cat-${id}`}>
          <div class="products-grid">
            {items.map((product) => (
              <a class="product-card" href={`/${lang}/products/${product.slug}/`}>
                <div class="product-image">
                  <img src={product.image} alt={product.name} loading="lazy" />
                </div>
                <div class="product-content">
                  <div class={`product-brand ${brandClass}`}>{product.series}</div>
                  <h3 class="product-title">{product.shortName}</h3>
                  <p class="product-desc">{product.intro}</p>
                  <div class="product-price">{product.priceLabel}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Cabinets -->
  <section class="section cabinets-section" id="cabinets">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'cabinets.title')}</h2>
        <p class="section-subtitle">{t(lang, 'cabinets.subtitle')}</p>
      </div>
      <div class="cabinets-grid">
        {cabinetProducts.map((product) => (
          <a class="cabinet-card" href={`/${lang}/products/${product.slug}/`}>
            <div class="cabinet-image">
              <img src={product.image} alt={product.name} loading="lazy" />
            </div>
            <div class="cabinet-content">
              <h3 class="cabinet-title">{product.shortName}</h3>
              <div class="cabinet-price">{product.priceLabel}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section services-section" id="services">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'services.title')}</h2>
        <p class="section-subtitle">{t(lang, 'services.subtitle')}</p>
      </div>
      <div class="services-grid">
        {[
          { key: 'plc', items: svcPlcItems, href: 'https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I%20need%20PLC%20programming%20service.' },
          { key: 'software', items: svcSoftItems, href: 'https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I%20need%20automation%20software.' },
          { key: 'custom', items: svcCustomItems, href: 'https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I%20need%20a%20custom%20training%20kit.' },
        ].map(({ key, items, href }) => (
          <article class="service-card">
            <h3 class="service-title">{t(lang, `services.${key}.title`)}</h3>
            <p class="service-desc">{t(lang, `services.${key}.desc`)}</p>
            <ul class="service-list">
              {(items as string[]).map((item: string) => <li>{item}</li>)}
            </ul>
            <a class="service-btn" href={href} target="_blank">{t(lang, `services.${key}.cta`)}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section why-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'why.title')}</h2>
      </div>
      <div class="why-grid">
        {(whyItems as any[]).map((item: any) => (
          <article class="why-card">
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'faq.title')}</h2>
      </div>
      <div class="faq-list">
        {(faqItems as any[]).map((item: any) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <div class="faq-answer">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'testimonials.title')}</h2>
        <p class="section-subtitle">{t(lang, 'testimonials.subtitle')}</p>
      </div>
      <div class="testimonials-grid">
        {(testimonialItems as any[]).map((item: any) => (
          <article class="testimonial-card">
            <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="testimonial-quote">{item.quote}</p>
            <div class="testimonial-author">
              <div class="testimonial-name">{item.name}</div>
              <div class="testimonial-role">{item.role}</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section process-section" id="how-to-order">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t(lang, 'process.title')}</h2>
      </div>
      <div class="process-steps">
        {(processSteps as any[]).map((step: any, i: number) => (
          <div class="process-step">
            <div class="step-number">{i + 1}</div>
            <div class="step-title">{step.title}</div>
            <div class="step-desc">{step.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="contact">
    <div class="container">
      <div class="cta-box">
        <h2>{t(lang, 'cta.title')}</h2>
        <p>{t(lang, 'cta.desc')}</p>
        <div class="cta-box__actions">
          <a class="button button--primary" href="https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I'm%20interested%20in%20your%20products%20and%20services." target="_blank">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            {t(lang, 'cta.btn')}
          </a>
          <a class="button button--secondary" href="mailto:peggy@kernal-automation.com">peggy@kernal-automation.com</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll('.cat-tab');
    const panels = document.querySelectorAll('.cat-content');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach((p) => p.classList.remove('active'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        document.getElementById(`cat-${(tab as HTMLElement).dataset.cat}`)?.classList.add('active');
      });
    });
  </script>
</BaseLayout>
