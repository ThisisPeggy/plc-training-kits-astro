---
import SiteLayout from '../layouts/SiteLayout.astro';

const faqCategories = [
  {
    title: 'Products & Kits',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
    items: [
      { q: "What's included in each training kit?", a: 'Each kit includes the hardware, complete user manual with wiring diagrams, step-by-step training videos, and 1-year warranty. All documentation is in English (Chinese available on request).' },
      { q: 'Can you customize the training kit?', a: 'Yes! We can customize kits with different PLC brands (Siemens, Mitsubishi, Allen-Bradley, etc.), add or remove components, and adjust configurations to match your curriculum.' },
      { q: 'What PLC brands do you support?', a: 'We currently offer training kits for Siemens S7-1200, Mitsubishi FX5U, and Allen-Bradley Micro850/MicroLogix platforms. We also provide compact control cabinets for motor and process control training.' },
      { q: 'Can I request a product demo or sample?', a: 'We can provide product photos, videos, and detailed specifications. For bulk orders, we may arrange a sample unit. Contact Peggy to discuss your needs.' },
    ],
  },
  {
    title: 'Payment',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    items: [
      { q: 'What payment methods do you accept?', a: 'We accept T/T (bank transfer), PayPal, and Alipay. For PayPal, a 4.4% + $0.30 fee applies. Payment is typically 100% in advance.' },
      { q: 'Do you offer bulk discounts?', a: 'Yes! Schools and training centers ordering multiple units qualify for special pricing. Contact Peggy with your requirements for a custom quote.' },
      { q: 'Can I get an invoice or proforma invoice (PI)?', a: 'Yes. After confirming your order details, we will send a proforma invoice with product specifications, pricing, and payment instructions.' },
    ],
  },
  {
    title: 'Shipping & Delivery',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>',
    items: [
      { q: 'How long is shipping?', a: 'Express (DHL/FedEx): 5-7 days. Air freight: 7-14 days. Sea freight: 30-45 days. We ship EXW, FOB, CIF, or DDP based on your preference.' },
      { q: 'Which countries do you ship to?', a: 'We ship to 15+ countries worldwide including the Middle East, Southeast Asia, Africa, South America, and Europe. DHL and FedEx are our primary carriers for express delivery.' },
      { q: 'Can I track my shipment?', a: 'Yes. After shipping, we provide the tracking number and carrier details so you can monitor your delivery in real time.' },
    ],
  },
  {
    title: 'Warranty & Support',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    items: [
      { q: 'What does the 1-year warranty cover?', a: 'The 1-year warranty covers all manufacturing defects in hardware components (PLC modules, I/O cards, sensors, and wiring). It does not cover damage from misuse, incorrect wiring, or liquid exposure.' },
      { q: 'What is your return or exchange policy?', a: 'If your kit arrives with damaged or missing components, contact us within 7 days of receipt with photos. We will ship replacement parts or arrange an exchange at no additional cost.' },
      { q: 'Do you offer technical support after purchase?', a: 'Yes. We provide ongoing technical support including remote assistance, troubleshooting guidance, and access to our engineering team for product-related questions.' },
    ],
  },
];

const totalQuestions = faqCategories.reduce((sum, cat) => sum + cat.items.length, 0);

const allFaqItems = faqCategories.flatMap((cat) => cat.items);
const faqSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: allFaqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://plc-training-kits.tech/' },
      { '@type': 'ListItem', position: 2, name: 'FAQ', item: 'https://plc-training-kits.tech/faq/' },
    ],
  },
];
---

<SiteLayout
  title="FAQ | PLC Training Kits — Frequently Asked Questions"
  description="Answers to common questions about PLC training kits, payment methods, shipping, warranty, and technical support."
  canonicalPath="/faq/"
  schemaJsonLd={faqSchema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb breadcrumb--on-dark">
        <a href="/">Home</a> / <span>FAQ</span>
      </div>
      <h1>Frequently Asked Questions</h1>
      <p class="page-hero__desc" style="margin-bottom:1.5rem;">
        {totalQuestions} answers about our training kits, ordering process, shipping, and after-sales support.
      </p>
    </div>
  </section>

  <!-- FAQ Categories -->
  <section class="faq-page-content">
    <div class="container">
      {faqCategories.map((cat) => (
        <div class="faq-category" id={`faq-${cat.title.toLowerCase().replace(/[^a-z]+/g, '-')}`}>
          <div class="faq-category__header">
            <span class="faq-category__icon" set:html={cat.icon} />
            <h2 class="faq-category__title">{cat.title}</h2>
          </div>
          <div class="faq-category__list">
            {cat.items.map((item) => (
              <details class="faq-item">
                <summary>{item.q}</summary>
                <div class="faq-answer"><div class="faq-answer__inner">{item.a}</div></div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-banner__box">
        <h2>Still have questions?</h2>
        <p>Contact Peggy directly — she typically responds within a few hours.</p>
        <div class="cta-banner__actions">
          <a class="button button--whatsapp" href="https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I%20have%20a%20question%20about%20your%20PLC%20training%20kits." target="_blank">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Peggy
          </a>
          <a class="button button--secondary" href="mailto:peggy@kernal-automation.com">Email Peggy</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .faq-page-content {
    padding: 3rem 0 2rem;
  }

  .faq-category {
    max-width: 720px;
    margin: 0 auto 2rem;
    scroll-margin-top: 100px;
  }

  .faq-category__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .faq-category__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--primary);
    color: #fff;
    flex-shrink: 0;
  }

  .faq-category__title {
    margin: 0;
    color: var(--primary);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .faq-category__list {
    display: grid;
    gap: 0.75rem;
  }
</style>
