---
import { Image } from 'astro:assets';
import SiteLayout from '../layouts/SiteLayout.astro';
import { products } from '../data/products';

const siemensProducts = products.filter((p) => p.category === 'siemens');
const mitsubishiProducts = products.filter((p) => p.category === 'mitsubishi');
const abProducts = products.filter((p) => p.category === 'allen-bradley');
const cabinetProducts = products.filter((p) => p.category === 'control-cabinets');
const heroProduct = siemensProducts[0];

const siteUrl = 'https://plc-training-kits.tech';

const faqItems = [
  { q: "What's included in each training kit?", a: 'Each kit includes the hardware, complete user manual with wiring diagrams, step-by-step training videos, and 1-year warranty. All documentation is in English (Chinese available on request).' },
  { q: 'Can you customize the training kit?', a: 'Yes! We can customize kits with different PLC brands (Siemens, Mitsubishi, Allen-Bradley, etc.), add or remove components, and adjust configurations to match your curriculum.' },
  { q: 'What payment methods do you accept?', a: 'We accept T/T (bank transfer), PayPal, and Alipay. For PayPal, a 4.4% + $0.30 fee applies. Payment is typically 100% in advance.' },
];

const schemaOrg = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'PLC Training Kits',
    url: siteUrl,
    description: 'Professional PLC training kits with Siemens S7-1200, Mitsubishi FX5U, and Allen-Bradley Micro850.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: "Peggy's Automation Store",
    alternateName: 'Kernal Automation - System Integration Department',
    image: `${siteUrl}/logo.png`,
    logo: `${siteUrl}/logo.png`,
    telephone: '+86-176-1205-1841',
    email: 'peggy@kernal-automation.com',
    url: siteUrl,
    areaServed: 'Worldwide',
    priceRange: '$95-$2100',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Dongguan',
      addressRegion: 'Guangdong',
      addressCountry: 'CN',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 23.0208,
      longitude: 113.7518,
    },
    sameAs: [
      'https://www.linkedin.com/company/kernal-automation-co-limited/',
      'https://www.youtube.com/@PeggyinKernal',
      'https://kernal-automation.com/',
    ],
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '47',
      bestRating: '5',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'PLC Training Kits',
    url: `${siteUrl}/#products`,
    numberOfItems: 15,
    itemListElement: products.filter((p) => p.category !== 'control-cabinets').map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteUrl}/products/${p.slug}/`,
      name: p.name,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
];

const whyItems = [
  { icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>', title: 'Complete Documentation', desc: 'Every kit includes detailed manuals and wiring diagrams ready for classroom use.' },
  { icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>', title: 'Training Videos', desc: 'Step-by-step video tutorials covering all training tasks.' },
  { icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>', title: 'Customization', desc: 'Need different configurations? Our engineers can customize kits for you.' },
  { icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>', title: 'Technical Support', desc: 'Direct access to our engineers for technical questions.' },
  { icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>', title: 'Global Shipping', desc: 'DHL, FedEx, air or sea freight. We ship to 50+ countries.' },
  { icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>', title: 'Bulk Pricing', desc: 'Special pricing for schools ordering multiple units.' },
];

const testimonials = [
  { quote: '"We ordered 15 sets of the S7-1200 VFD kits for our automation lab. Everything arrived perfectly packed, the documentation is thorough and the students started programming on day one."', name: 'Mohammed Al-Rashidi', role: 'Lab Manager, Vocational Training College — Saudi Arabia' },
  { quote: '"Peggy was super responsive and helped us select the right Mitsubishi kits for our curriculum. The training videos saved us hours of preparation time."', name: 'Rodrigo Castillo', role: 'Instructor, Technical Institute — Mexico' },
  { quote: '"Excellent quality at a very fair price. The custom configuration service was a big plus — we got exactly the components our course required. Shipped DHL in 6 days."', name: 'David Patel', role: 'Purchasing Manager, Engineering Academy — India' },
];

const processSteps = [
  { title: 'Inquiry', desc: 'Contact Peggy' },
  { title: 'Quote', desc: 'Receive PI' },
  { title: 'Payment', desc: 'T/T, PayPal' },
  { title: 'Shipping', desc: 'Track shipment' },
  { title: 'Support', desc: 'Tech support' },
];
---

<SiteLayout
  title="PLC Training Kits & Control Cabinets | Siemens, Mitsubishi, Allen-Bradley"
  description="Complete Siemens S7-1200, Mitsubishi FX5U, and Allen-Bradley training kits with wiring diagrams, step-by-step manuals, and training videos included. Trusted by schools and enterprises in 50+ countries. Ships in 5-7 days via DHL/FedEx."
  schemaJsonLd={schemaOrg}
>
  <!-- Hero -->
  <section class="home-hero" id="overview">
    <div class="container home-hero__inner">
      <div class="home-hero__content">
        <div class="home-hero__copy">
          <span class="hero-badge">Kernal Automation — System Integration Dept.</span>
          <h1>Ready-to-Teach PLC Training Kits — Plug In, Power On, Start Teaching</h1>
          <p class="home-hero__desc">
            Complete Siemens S7-1200, Mitsubishi FX5U, and Allen-Bradley training kits with wiring diagrams, step-by-step manuals, and training videos included. Trusted by schools and enterprises in 50+ countries. Ships in 5–7 days via DHL/FedEx.
          </p>
          <div class="home-hero__actions">
            <a class="button button--primary" href={`https://wa.me/8617612051841?text=${encodeURIComponent("Hi Peggy, I'm looking for a PLC training kit for my school/organization. Can you share the catalog?")}`} target="_blank">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chat with Peggy
            </a>
            <a class="button button--secondary" href="#products">Training Kits</a>
          </div>
        </div>
        <div class="home-hero__visual">
          <div class="hero-product-showcase">
            <div class="hero-product-showcase__frame">
              <Image src={heroProduct.image} alt={heroProduct.name} width={600} height={450} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat-box"><strong>20+</strong><span>Training Kit Models</span></div>
      <div class="stat-box"><strong>15+</strong><span>Countries Shipped</span></div>
      <div class="stat-box"><strong>100%</strong><span>With Documentation</span></div>
      <div class="stat-box"><strong>1 Year</strong><span>Warranty</span></div>
    </div>
  </section>

  <!-- Products -->
  <section class="section products-section" id="products">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">PLC Training Kits</h2>
        <p class="section-subtitle">Professional training equipment for automation skills</p>
      </div>

      <div class="cat-tabs" role="tablist">
        <button class="cat-tab siemens active" data-cat="siemens" role="tab" aria-selected="true">Siemens S7-1200</button>
        <button class="cat-tab mitsubishi" data-cat="mitsubishi" role="tab" aria-selected="false">Mitsubishi FX5U</button>
        <button class="cat-tab ab" data-cat="ab" role="tab" aria-selected="false">Allen-Bradley</button>
      </div>

      {[
        { id: 'siemens', items: siemensProducts, brandClass: 'siemens' },
        { id: 'mitsubishi', items: mitsubishiProducts, brandClass: 'mitsubishi' },
        { id: 'ab', items: abProducts, brandClass: 'ab' },
      ].map(({ id, items, brandClass }, catIdx) => (
        <div class={`cat-content ${catIdx === 0 ? 'active' : ''}`} id={`cat-${id}`}>
          <div class="products-grid">
            {items.map((product) => (
              <a class="product-card" href={`/products/${product.slug}/`}>
                <div class="product-image">
                  <Image src={product.image} alt={product.name} width={400} height={300} loading="lazy" />
                </div>
                <div class="product-content">
                  <div class={`product-brand ${brandClass}`}>{product.series}</div>
                  <h3 class="product-title">{product.shortName}</h3>
                  <p class="product-desc">{product.intro}</p>
                  <div class="product-price">{product.priceLabel}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Cabinets -->
  <section class="section cabinets-section" id="cabinets">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Control Cabinets</h2>
        <p class="section-subtitle">Compact control equipment for process and motor control training</p>
      </div>
      <div class="cabinets-grid">
        {cabinetProducts.map((product) => (
          <a class="cabinet-card" href={`/products/${product.slug}/`}>
            <div class="cabinet-image">
              <Image src={product.image} alt={product.name} width={300} height={220} loading="lazy" />
            </div>
            <div class="cabinet-content">
              <h3 class="cabinet-title">{product.shortName}</h3>
              <div class="cabinet-price">{product.priceLabel}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">FAQ</h2>
        <p class="section-subtitle">Quick answers to the most common questions</p>
      </div>
      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <div class="faq-answer">{item.a}</div>
          </details>
        ))}
      </div>
      <div style="text-align:center;margin-top:1.5rem;">
        <a class="button button--secondary" href="/faq/">View All FAQ &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section why-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Why Choose Us</h2>
      </div>
      <div class="why-grid">
        {whyItems.map((item) => (
          <article class="why-card">
            <span class="why-icon" set:html={item.icon} />
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-scroll-section">
    <div class="container">
      <p class="testimonials-label">Trusted by vocational schools and automation engineers worldwide</p>
    </div>
    <div class="testimonials-track">
      {[...testimonials, ...testimonials].map((item) => (
        <article class="testimonial-slide">
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial-quote">{item.quote}</p>
          <div class="testimonial-author">
            <div class="testimonial-name">{item.name}</div>
            <div class="testimonial-role">{item.role}</div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="section process-section" id="how-to-order">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">How to Order</h2>
      </div>
      <div class="process-steps">
        {processSteps.map((step, i) => (
          <div class="process-step">
            <div class="step-number">{i + 1}</div>
            <div class="step-title">{step.title}</div>
            <div class="step-desc">{step.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="contact">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to Get Started?</h2>
        <p>Contact Peggy for product inquiries, bulk pricing, or custom requirements.</p>
        <div class="cta-box__actions">
          <a class="button button--primary" href="https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I'm%20interested%20in%20your%20products%20and%20services." target="_blank">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat with Peggy on WhatsApp
          </a>
        </div>
        <p class="cta-email">Or email: <a href="mailto:peggy@kernal-automation.com">peggy@kernal-automation.com</a></p>
      </div>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll('.cat-tab');
    const panels = document.querySelectorAll('.cat-content');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach((p) => p.classList.remove('active'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        document.getElementById(`cat-${(tab as HTMLElement).dataset.cat}`)?.classList.add('active');
      });
    });
  </script>
</SiteLayout>
