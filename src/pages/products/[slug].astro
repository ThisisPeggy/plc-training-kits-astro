---
import { Image } from 'astro:assets';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { products } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const related = products.filter((item) => item.category === product.category && item.slug !== product.slug).slice(0, 3);
const siteUrl = 'https://plc-training-kits.tech';
const categoryHrefMap = {
  siemens: '/products/siemens/',
  mitsubishi: '/products/mitsubishi/',
  'allen-bradley': '/products/allen-bradley/',
  'control-cabinets': '/products/cabinets/',
};
const categoryLabelMap = {
  siemens: 'Siemens S7-1200 training kits',
  mitsubishi: 'Mitsubishi FX5U training kits',
  'allen-bradley': 'Allen-Bradley training kits',
  'control-cabinets': 'control cabinets',
};

const isYoutube =
  typeof product.videoUrl === 'string' &&
  (product.videoUrl.includes('youtube.com') || product.videoUrl.includes('youtu.be'));
const youtubeEmbed = isYoutube
  ? product.videoUrl!
      .replace('youtu.be/', 'youtube.com/embed/')
      .replace('watch?v=', 'embed/')
  : undefined;

const schemaOrg = [
  {
    '@context': 'https://schema.org/',
    '@type': 'Product',
    name: product.name,
    description: product.description,
    image: `${siteUrl}${product.image.src}`,
    sku: product.sku,
    brand: { '@type': 'Brand', name: product.brand },
    manufacturer: {
      '@type': 'Organization',
      name: 'Kernal Automation',
      url: 'https://plc-training-kits.tech',
      sameAs: [
        'https://www.linkedin.com/company/kernal-automation-co-limited/',
        'https://www.youtube.com/@PeggyinKernal',
        'https://kernal-automation.com/',
      ],
    },
    offers: {
      '@type': 'Offer',
      url: `${siteUrl}/products/${product.slug}/`,
      priceCurrency: 'USD',
      price: String(product.priceValue),
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      seller: { '@type': 'Organization', name: 'Kernal Automation' },
    },
  },
...(product.faq && product.faq.length > 0 ? [{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: product.faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  }] : []),
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: product.category === 'control-cabinets' ? 'Control Cabinets' : 'Training Kits', item: `${siteUrl}/#${product.category === 'control-cabinets' ? 'cabinets' : 'products'}` },
      { '@type': 'ListItem', position: 3, name: product.shortName, item: `${siteUrl}/products/${product.slug}/` },
    ],
  },
];

const hasVideo = Boolean(product.videoUrl);
---

<SiteLayout
  title={`${product.name} | PLC Training Kits`}
  description={product.description}
  image={product.image.src}
  canonicalPath={`/products/${product.slug}/`}
  schemaJsonLd={schemaOrg}
>
  <section class="product-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> /
        <a href={product.category === 'control-cabinets' ? '/#cabinets' : '/#products'}>{product.category === 'control-cabinets' ? 'Control Cabinets' : 'Training Kits'}</a> /
        <span>{product.shortName}</span>
      </div>

      <div class="product-shell">
        <div class={`product-column ${hasVideo ? 'product-column--with-video' : 'product-column--no-video'}`}>
          <div class="product-panel product-media">
            <Image src={product.image} alt={product.name} width={600} height={500} />
          </div>
          {product.videoUrl && (
            <div class="product-panel product-video">
              <div class="product-video__head">
                <h2>Video</h2>
                <p>Product demo or training overview.</p>
              </div>
              {isYoutube ? (
                <div class="video-frame">
                  <iframe
                    src={youtubeEmbed}
                    title={`${product.name} video`}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
              ) : (
                <video controls preload="metadata" poster={product.videoPoster}>
                  <source src={product.videoUrl} />
                </video>
              )}
            </div>
          )}
          <div class="product-panel product-summary">
            <div class="product-summary__row">
              <span>Brand</span>
              <strong>{product.brand}</strong>
            </div>
            <div class="product-summary__row">
              <span>Series</span>
              <strong>{product.series}</strong>
            </div>
            <div class="product-summary__row">
              <span>SKU</span>
              <strong>{product.sku}</strong>
            </div>
            <div class="product-summary__row">
              <span>Price</span>
              <strong>{product.priceLabel}</strong>
            </div>
          </div>
        </div>

        <div class="product-panel product-copy">
          <span class={`tag tag--${product.category}`}>{product.brand}</span>
          <h1>{product.name}</h1>
          <p class="product-kicker">{product.intro}</p>
          <div class="product-meta">
            <div class="price">{product.priceLabel}</div>
            <span class="product-meta__series">{product.series}</span>
          </div>
          <ul class="feature-list">
            {product.features.map((feature) => <li>{feature}</li>)}
          </ul>
          {product.audience && (
            <div class="product-audience">
              <h2>Who Is This For</h2>
              <p>{product.audience}</p>
            </div>
          )}
          <div class="product-actions">
            <a class="button button--whatsapp" href={`https://wa.me/8617612051841?text=${encodeURIComponent(`Hi Peggy, I'm interested in the ${product.name}.`)}`} target="_blank">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Peggy
            </a>
            <a class="button button--secondary" href="mailto:peggy@kernal-automation.com">Email Peggy</a>
          </div>
        </div>
      </div>

      {product.specs && Object.keys(product.specs).length > 0 && (
        <div class="product-specs product-specs--full section">
          <div class="section-header">
            <h2 class="section-title">Technical Specifications</h2>
          </div>
          <table class="specs-table">
            <tbody>
              {Object.entries(product.specs).map(([key, value]) => (
                <tr>
                  <th>{key}</th>
                  <td>{value}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <div class="product-note">
            Complete hardware setup, documentation, and support for classroom or training-room use.
          </div>
        </div>
      )}

      <div class="section">
        <div class="section-header">
          <h2 class="section-title">More Buying Information</h2>
          <p class="section-subtitle">Use these pages to compare related products, shipping details, and customization options.</p>
        </div>
        <div class="related-grid">
          <a class="related-card" href={categoryHrefMap[product.category]}>
            <span class={`tag tag--${product.category}`}>{product.brand}</span>
            <h3>Browse More {categoryLabelMap[product.category]}</h3>
            <p style="color:var(--text-light);font-size:0.92rem;margin:0 0 0.5rem;">Compare other products in the same platform or category before placing an order.</p>
            <div class="card__footer">
              <div class="price">Category Page</div>
              <span class="card__link">Open &rarr;</span>
            </div>
          </a>
          <a class="related-card" href="/faq/">
            <span class={`tag tag--${product.category}`}>FAQ</span>
            <h3>Check Shipping, Payment, and Warranty FAQs</h3>
            <p style="color:var(--text-light);font-size:0.92rem;margin:0 0 0.5rem;">Review common buying questions about delivery time, documentation, support, and customization.</p>
            <div class="card__footer">
              <div class="price">Support Info</div>
              <span class="card__link">Open &rarr;</span>
            </div>
          </a>
          <a class="related-card" href="/services/">
            <span class={`tag tag--${product.category}`}>Services</span>
            <h3>Need Customization or Engineering Support?</h3>
            <p style="color:var(--text-light);font-size:0.92rem;margin:0 0 0.5rem;">See available services for PLC programming, software supply, and custom kit design.</p>
            <div class="card__footer">
              <div class="price">Services</div>
              <span class="card__link">Open &rarr;</span>
            </div>
          </a>
        </div>
      </div>

      {product.faq && product.faq.length > 0 && (
        <div class="section product-faq-section">
          <div class="section-header">
            <h2 class="section-title">Frequently Asked Questions</h2>
            <p class="section-subtitle">Common questions about this product.</p>
          </div>
          <div class="faq-list">
            {product.faq.map((item) => (
              <details class="faq-item">
                <summary>{item.q}</summary>
                <div class="faq-answer"><div class="faq-answer__inner">{item.a}</div></div>
              </details>
            ))}
          </div>
        </div>
      )}

      {related.length > 0 && (
        <div class="section section--related">
          <div class="section-header">
            <h2 class="section-title">Related Products</h2>
            <p class="section-subtitle">Other products in the same family.</p>
          </div>
          <div class="related-grid">
            {related.map((item) => (
              <a class="related-card" href={`/products/${item.slug}/`}>
                <span class={`tag tag--${item.category}`}>{item.series}</span>
                <h3>{item.shortName}</h3>
                <p style="color:var(--text-light);font-size:0.92rem;margin:0 0 0.5rem;">{item.intro}</p>
                <div class="card__footer">
                  <div class="price">{item.priceLabel}</div>
                  <span class="card__link">View &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</SiteLayout>
