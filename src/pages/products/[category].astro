---
import { Image } from 'astro:assets';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { products, categories } from '../../data/products';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const items = products.filter((p) => p.category === cat.category);
const label = cat.category === 'control-cabinets' ? 'Control Cabinets' : 'Training Kits';
const supportLink = cat.category === 'control-cabinets' ? '/services/' : '/faq/';
const supportLabel = cat.category === 'control-cabinets' ? 'See related automation services' : 'Read buying and shipping FAQs';

const categoryContent = {
  siemens: {
    buyerTitle: 'Who Usually Buys Siemens S7-1200 PLC Training Kits',
    buyerText: 'These Siemens PLC training kits are commonly purchased by vocational schools, university automation labs, industrial training centers, and distributors looking for Siemens-compatible classroom equipment. Popular search intent includes Siemens PLC trainer, S7-1200 training kit, PROFINET training equipment, PID control trainer, and motion control training system.',
    useCases: ['PLC programming classes with Siemens TIA Portal', 'Industrial communication training with PROFINET and remote I/O', 'Process control lessons covering PID and analog signals', 'Motion control and pneumatic sequencing practice'],
  },
  mitsubishi: {
    buyerTitle: 'Who Usually Buys Mitsubishi FX5U Training Kits',
    buyerText: 'These Mitsubishi FX5U training kits fit schools and labs teaching GX Works 3, CC-Link communication, temperature control, motion control, and inverter applications. They are suitable for buyers searching for Mitsubishi PLC training equipment, FX5U motion trainer, CC-Link communication kit, and Mitsubishi VFD training kit.',
    useCases: ['Mitsubishi PLC programming and HMI integration training', 'CC-Link and Ethernet communication lessons', 'PID temperature control and analog signal practice', '2-axis interpolation and positioning training'],
  },
  'allen-bradley': {
    buyerTitle: 'Who Usually Buys Allen-Bradley PLC Trainers',
    buyerText: 'Allen-Bradley training kits are typically used by technical schools, North America focused training centers, and buyers who need Micro850 or MicroLogix practical teaching equipment. Search intent here often includes Allen-Bradley PLC trainer, Micro850 training kit, PowerFlex training panel, and pneumatic control training equipment.',
    useCases: ['Micro850 and MicroLogix classroom training', 'EtherNet/IP, Modbus, and HMI exercises', 'AB VFD integration with PowerFlex drives', 'Pneumatic timing and sequencing training'],
  },
  cabinets: {
    buyerTitle: 'Who Usually Buys Control Cabinets',
    buyerText: 'These control cabinets are usually purchased for entry-level electrical training, maintenance practice, and compact process control demonstrations. They match search intent such as motor control training panel, PID temperature control cabinet, star-delta starter panel, liquid level control panel, and VFD water supply cabinet.',
    useCases: ['Motor starter and forward/reverse wiring practice', 'Liquid level and temperature control demonstrations', 'Reduced-voltage starting and protection training', 'Compact process control and maintenance education'],
  },
}[cat.slug];

const siteUrl = 'https://plc-training-kits.tech';
const categorySchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: cat.title,
    description: cat.description,
    url: siteUrl + '/products/' + cat.slug + '/',
    numberOfItems: items.length,
    itemListElement: items.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: siteUrl + '/products/' + p.slug + '/',
      name: p.name,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl + '/' },
      { '@type': 'ListItem', position: 2, name: cat.title, item: siteUrl + '/products/' + cat.slug + '/' },
    ],
  },
];
---

<SiteLayout
  title={cat.pageTitle}
  description={cat.description}
  canonicalPath={`/products/${cat.slug}/`}
  schemaJsonLd={categorySchema}
>
  <section class="product-list-page">
    <div class="container">
      <div class="page-header">
        <div class="breadcrumb">
          <a href="/">Home</a> / <span>{cat.title}</span>
        </div>
        <h1>{cat.title}</h1>
        <p class="page-intro">{cat.intro}</p>
        <div class="page-stats">
          <span><strong>{items.length}</strong> {label}</span>
          <span>Pre-wired & Ready to Use</span>
          <span>Complete Documentation</span>
        </div>
        <p class="page-intro" style="margin-top:0.9rem;">
          Need more details before you choose? <a href={supportLink}>{supportLabel}</a>.
        </p>
      </div>

      <div class={cat.gridClass}>
        {items.map((product) => (
          cat.cardStyle === 'product' ? (
            <a class="product-card" href={`/products/${product.slug}/`}>
              <div class="product-image">
                <Image src={product.image} alt={product.name} width={400} height={300} loading="lazy" />
              </div>
              <div class="product-content">
                <div class={`product-brand ${cat.brandClass}`}>{product.series}</div>
                <h3 class="product-title">{product.shortName}</h3>
                <p class="product-desc">{product.intro}</p>
                <div class="product-card__footer">
                  <div class="product-price">{product.priceLabel}</div>
                  <span class="product-card__cta">View Details</span>
                </div>
              </div>
            </a>
          ) : (
            <a class="cabinet-card" href={`/products/${product.slug}/`}>
              <div class="cabinet-image">
                <Image src={product.image} alt={product.name} width={300} height={220} loading="lazy" />
              </div>
              <div class="cabinet-content">
                <h3 class="cabinet-title">{product.shortName}</h3>
                <p class="cabinet-desc">{product.intro}</p>
                <div class="cabinet-card__footer">
                  <div class="cabinet-price">{product.priceLabel}</div>
                  <span class="cabinet-card__cta">View Details</span>
                </div>
              </div>
            </a>
          )
        ))}
      </div>

      <section class="category-guide">
        <div class="category-guide__card">
          <h2>{categoryContent.buyerTitle}</h2>
          <p>{categoryContent.buyerText}</p>
          <div class="category-guide__grid">
            {categoryContent.useCases.map((item) => (
              <div class="category-guide__item">{item}</div>
            ))}
          </div>
        </div>
      </section>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="cta-banner__box">
        <h2>Need help choosing the right {cat.category === 'control-cabinets' ? 'cabinet' : 'kit'}?</h2>
        <p>Contact Peggy for product recommendations, customization options, and bulk pricing.</p>
        <div class="cta-banner__actions">
          <a class="button button--whatsapp" href={`https://wa.me/8617612051841?text=${encodeURIComponent(cat.whatsappText)}`} target="_blank">WhatsApp Peggy</a>
          <a class="button button--secondary" href="mailto:peggy@kernal-automation.com">Email Peggy</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .category-guide {
    margin-top: 2rem;
  }

  .category-guide__card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--bg);
  }

  .category-guide__card h2 {
    margin: 0 0 0.75rem;
    color: var(--primary);
    font-size: 1.3rem;
  }

  .category-guide__card p {
    margin: 0;
    color: var(--text-light);
    line-height: 1.7;
  }

  .category-guide__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .category-guide__item {
    padding: 0.95rem 1rem;
    border-radius: 14px;
    background: var(--white);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.92rem;
  }

  @media (max-width: 768px) {
    .category-guide__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
