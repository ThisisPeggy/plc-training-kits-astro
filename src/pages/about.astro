---
import SiteLayout from '../layouts/SiteLayout.astro';

const siteUrl = 'https://plc-training-kits.tech';

const aboutSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Kernal Automation',
    url: `${siteUrl}/about/`,
    description: 'About Kernal Automation, a PLC training kit manufacturer and automation supplier serving schools, labs, and enterprise training centers.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Kernal Automation Co., Ltd.',
    alternateName: 'Kernal Automation - System Integration Department',
    url: siteUrl,
    logo: `${siteUrl}/logo.png`,
    description: 'Founded in 2004, headquartered in Shenzhen. Industrial automation company with 400+ professionals, 125+ brand partners, and 56,285 SKUs. PLC training kits and automation solutions for 15+ countries.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Shenzhen',
      addressRegion: 'Guangdong',
      addressCountry: 'CN',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+86-176-1205-1841',
      contactType: 'sales',
      email: 'peggy@kernal-automation.com',
      availableLanguage: ['English', 'Chinese'],
    },
    sameAs: [
      'https://www.linkedin.com/company/kernal-automation-co-limited/',
      'https://www.youtube.com/@PeggyinKernal',
      'https://kernal-automation.com/',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl + '/' },
      { '@type': 'ListItem', position: 2, name: 'About', item: siteUrl + '/about/' },
    ],
  },
];

const strengths = [
  'Nearly 400 professionals across 4 branches',
  'Collaborating with 125+ brands, offering 56,285 SKUs',
  'Main warehouse in Huizhou with factory and logistics',
  'Transit warehouse close to Hong Kong for fast global shipping',
  'Ships via DHL, FedEx, UPS, TNT, and sea freight',
  'Specialized selection team and dedicated sales staff',
  'Continuous technical support from IT and engineers',
  'Premium supply with efficient delivery speed',
];

const milestones = [
  { year: '2004', event: 'Founded in Shenzhen.' },
  { year: '2007', event: 'Kernal Automation officially named. Started manufacturing PLCs, sensors, and HMIs.' },
  { year: '2010', event: 'Expanded to inverters, servo drives, and stepper motors.' },
  { year: '2017', event: 'Partnering with Siemens, AB, ABB, Schneider, and more international brands.' },
  { year: '2022', event: 'International expansion - Changsha Branch established.' },
  { year: '2023', event: 'Opened Bayern (Germany) and Guangzhou offices.' },
];

const resourceLinks = [
  { href: '/products/siemens/', label: 'Siemens S7-1200 Training Kits', desc: 'Explore Siemens PLC training systems for VFD, PID, communication, motion, and pneumatic lessons.' },
  { href: '/products/mitsubishi/', label: 'Mitsubishi FX5U Training Kits', desc: 'Browse Mitsubishi kits for CC-Link, motion control, PID, VFD, and pneumatic training.' },
  { href: '/products/allen-bradley/', label: 'Allen-Bradley Training Kits', desc: 'See Micro850 and MicroLogix training equipment for labs and vocational schools.' },
  { href: '/services/', label: 'Automation Services', desc: 'Review PLC programming, software supply, and custom training kit design services.' },
];
---

<SiteLayout
  title="About Us | Kernal Automation - PLC Training Kit Manufacturer"
  description="Kernal Automation - founded in 2004, headquartered in Shenzhen. 400+ professionals, 125+ brands, 56,285 SKUs. PLC training kits and automation solutions for schools and enterprises in 15+ countries."
  canonicalPath="/about/"
  schemaJsonLd={aboutSchema}
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb breadcrumb--on-dark" aria-label="Breadcrumb">
        <a href="/">Home</a> / <span>About</span>
      </nav>
      <h1>About Kernal Automation</h1>
      <p class="page-hero__desc">
        Founded in 2004 in Shenzhen. 400+ professionals, 4 branches across China and Germany, 125+ brand partners, and 56,285 SKUs.
      </p>
    </div>
  </section>

  <section class="about-content">
    <div class="container">
      <article class="about-block">
          <h2 class="about-block__title">Who We Are</h2>
          <p class="about-block__desc">
            Kernal Automation was founded in 2004 in Shenzhen, China. With 4 branches - Huizhou (factory, warehouse, sales), Changsha (sales), Guangzhou, and Bayern, Germany - we serve customers across 15+ countries.
          </p>
          <p class="about-block__detail">
            Our System Integration Department designs PLC training kits and control cabinets for vocational schools, universities, and enterprise training programs.
          </p>
      </article>

      <article class="about-block about-block--alt">
          <h2 class="about-block__title">Why Buyers Choose Us</h2>
          <p class="about-block__desc">
            With 400+ professionals and partnerships with 125+ brands, we combine deep supply chain expertise with pre-sales quality assurance and comprehensive after-sales support.
          </p>
          <ul class="about-block__list">
            {strengths.map((item) => <li>{item}</li>)}
          </ul>
      </article>

      <article class="about-block">
          <h2 class="about-block__title">Our Journey</h2>
          <div class="about-timeline">
            {milestones.map((item) => (
              <div class="about-timeline__item">
                <div class="about-timeline__year">{item.year}</div>
                <div class="about-timeline__event">{item.event}</div>
              </div>
            ))}
          </div>
      </article>

      <article class="about-block about-block--alt">
          <h2 class="about-block__title">Contact Peggy</h2>
          <p class="about-block__desc">
            Peggy is your direct contact for product recommendations, custom kit requirements, pricing, and project follow-up.
          </p>
          <p class="about-block__detail">
            She works with the engineering team to match training equipment to your curriculum, lab setup, and purchasing needs.
          </p>
          <div class="about-contact">
            <a href="https://wa.me/8617612051841" target="_blank">WhatsApp: +86 176 1205 1841</a>
            <a href="mailto:peggy@kernal-automation.com">peggy@kernal-automation.com</a>
          </div>
      </article>

      <article class="about-block">
          <h2 class="about-block__title">Explore Our PLC Training Equipment</h2>
          <p class="about-block__desc">
            If you are comparing product lines or planning an automation lab purchase, start with the most relevant category below.
          </p>
          <div class="resource-grid">
            {resourceLinks.map((link) => (
              <a class="resource-card" href={link.href}>
                <h3>{link.label}</h3>
                <p>{link.desc}</p>
              </a>
            ))}
          </div>
      </article>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="cta-banner__box">
        <h2>Ready to equip your training lab?</h2>
        <p>Contact Peggy for recommendations, customization options, and bulk pricing.</p>
        <div class="cta-banner__actions">
          <a class="button button--whatsapp" href="https://wa.me/8617612051841" target="_blank">Chat with Peggy</a>
          <a class="button button--secondary" href="mailto:peggy@kernal-automation.com">Email Peggy</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .about-content {
    padding: 3rem 0 1rem;
  }

  .about-block {
    max-width: 720px;
    margin: 0 auto 1.5rem;
    padding: 2rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .about-block--alt {
    background: var(--bg);
  }

  .about-block__num {
    display: block;
    color: var(--text-light);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
  }

  .about-block__title {
    margin: 0 0 0.75rem;
    color: var(--primary);
    font-size: 1.3rem;
    font-weight: 700;
  }

  .about-block__desc {
    margin: 0 0 0.5rem;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .about-block__detail {
    margin: 0;
    color: var(--text-light);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .about-block__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .about-block__list li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text);
    font-size: 0.92rem;
  }

  .about-block__list li::before {
    content: '';
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--primary);
  }

  .about-timeline {
    margin-top: 0.75rem;
  }

  .about-timeline__item {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .about-timeline__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about-timeline__year {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .about-timeline__event {
    color: var(--text-light);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .about-contact {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-top: 1rem;
  }

  .about-contact a {
    color: var(--primary);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .about-contact a:hover {
    text-decoration: underline;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1rem;
  }

  .resource-card {
    display: block;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg);
  }

  .resource-card h3 {
    margin: 0 0 0.4rem;
    color: var(--primary);
    font-size: 1rem;
  }

  .resource-card p {
    margin: 0;
    color: var(--text-light);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .resource-card:hover {
    border-color: var(--primary);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .about-block__list {
      grid-template-columns: 1fr;
    }

    .resource-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
