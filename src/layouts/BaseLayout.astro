---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Lang, languages, locales } from '../i18n/config';
import { t, getLocalizedPath, getDir } from '../i18n/utils';

type Props = {
  lang: Lang;
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  schemaJsonLd?: object[];
};

const {
  lang,
  title = 'PLC Training Kits | Siemens, Mitsubishi & Allen-Bradley',
  description = 'Professional PLC training kits from $318 — Siemens S7-1200, Mitsubishi FX5U, and Allen-Bradley Micro850. Complete hardware, documentation & training videos. Global shipping.',
  image = '/assets/15 Siemens S7-1200 PLC & Frequency Inverter Practical Training Kit/2.jpg',
  canonicalPath = '',
  schemaJsonLd = [],
} = Astro.props;

const dir = getDir(lang);
const siteUrl = 'https://plc-training-kits.tech';
const fullImage = image.startsWith('http') ? image : `${siteUrl}${encodeURI(image)}`;
const canonicalUrl = `${siteUrl}${canonicalPath || getLocalizedPath(lang)}`;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Peggy Chan, Kernal Automation" />
    <meta name="msvalidate.01" content="F902455469F9DD5B4D85E3662D3FC213" />

    <link rel="canonical" href={canonicalUrl} />
    {locales.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${getLocalizedPath(l, canonicalPath)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:site_name" content="Peggy's Automation Store" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImage} />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YQPZ0DS24Q"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YQPZ0DS24Q');
    </script>

    {schemaJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-white">
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
