---
import { type Lang, languages } from '../i18n/config';
import { getLocalizedPath } from '../i18n/utils';

type Props = { lang: Lang };
const { lang } = Astro.props;
---

<div class="lang-switcher" style="position:relative;">
  <button id="langToggle" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 0.7rem;border:1px solid var(--border);border-radius:8px;background:white;font-size:0.85rem;font-weight:500;cursor:pointer;">
    {languages[lang].flag} {languages[lang].label}
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>
  <div id="langDropdown" style="display:none;position:absolute;right:0;top:110%;min-width:140px;background:white;border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,0.12);overflow:hidden;z-index:100;">
    {Object.entries(languages).map(([code, { label, flag }]) => (
      <a href={getLocalizedPath(code as Lang)} style={`display:block;padding:0.55rem 0.9rem;font-size:0.88rem;transition:background 0.15s;${code === lang ? 'background:#edf2f7;font-weight:600;' : ''}`}>
        {flag} {label}
      </a>
    ))}
  </div>
</div>

<script is:inline>
  const toggle = document.getElementById('langToggle');
  const dropdown = document.getElementById('langDropdown');
  toggle?.addEventListener('click', (e) => { e.stopPropagation(); dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none'; });
  document.addEventListener('click', () => { if (dropdown) dropdown.style.display = 'none'; });
</script>
