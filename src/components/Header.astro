---
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <img src="/logo.png" alt="Kernal Automation" />
      <span>Kernal Automation - SI Dept.</span>
    </a>
    <nav class="nav">
      <a href="/#products">Training Kits</a>
      <a href="/#cabinets">Control Cabinets</a>
      <a href="/services/">Services</a>
      <a href="/faq/">FAQ</a>
      <a href="/about/">About</a>
      <a href="/#contact">Contact</a>
    </nav>
    <div class="site-header__actions">
      <a class="button header-demo-link" href="/watch-demo/"><span>Watch Demo</span></a>
      <a class="button button--secondary" href="https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I%20need%20the%20latest%20PLC%20training%20kit%20catalog." target="_blank">Get Catalog</a>
      <button id="hamburgerBtn" class="hamburger-btn" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile side menu -->
<div id="sideMenu" class="side-menu">
  <div class="side-menu__inner">
    <button id="closeSideMenu" class="side-menu__close">&times;</button>
    <p class="side-menu__label">Navigation</p>
    <nav class="side-menu__nav">
      <a class="side-link" href="/#products">Training Kits</a>
      <a class="side-link" href="/#cabinets">Control Cabinets</a>
      <a class="side-link" href="/services/">Services</a>
      <a class="side-link" href="/faq/">FAQ</a>
      <a class="side-link" href="/about/">About</a>
      <a class="side-link" href="/#contact" data-contact-link>Contact</a>
    </nav>
    <div class="side-menu__footer">
      <a href="https://wa.me/8617612051841" target="_blank" class="side-menu__wa">WhatsApp Peggy</a>
      <a href="mailto:peggy@kernal-automation.com" class="side-menu__email">peggy@kernal-automation.com</a>
    </div>
  </div>
</div>
<div id="sideMenuOverlay" class="side-menu-overlay"></div>

<style is:global>
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .site-header__actions .button {
    min-height: 40px;
    padding: 0.62rem 1rem;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

  .header-demo-link {
    background: rgba(26, 54, 93, 0.08);
    color: var(--primary);
    border: 1px solid rgba(26, 54, 93, 0.12);
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
  }

  .header-demo-link:hover {
    background: rgba(26, 54, 93, 0.12);
    border-color: rgba(26, 54, 93, 0.2);
    transform: translateY(-1px);
  }

  .site-header__actions .button--secondary {
    background: #fff;
    color: var(--primary);
    border: 1px solid rgba(26, 54, 93, 0.14);
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
  }

  .site-header__actions .button--secondary:hover {
    border-color: rgba(26, 54, 93, 0.24);
    transform: translateY(-1px);
  }

  .hamburger-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
    border: none;
    background: none;
    cursor: pointer;
  }

  .hamburger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--primary);
    border-radius: 2px;
  }

  .side-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 1100;
    width: 280px;
    background: #fff;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .side-menu.open {
    transform: translateX(0);
  }

  .side-menu__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.25rem;
    overflow-y: auto;
  }

  .side-menu__close {
    align-self: flex-end;
    border: none;
    background: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-light);
  }

  .side-menu__label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 1rem 0 0.5rem;
  }

  .side-menu__nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .side-link {
    padding: 0.5rem 0;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .side-menu__footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.88rem;
  }

  .side-menu__wa {
    color: var(--whatsapp);
    font-weight: 600;
  }

  .side-menu__email {
    color: var(--text-light);
  }

  .side-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 1050;
    background: rgba(0, 0, 0, 0.4);
    display: none;
  }

  .side-menu-overlay.open {
    display: block;
  }

  @media (max-width: 768px) {
    .hamburger-btn { 
      display: flex;
      min-width: 44px;
      min-height: 44px;
      justify-content: center;
      align-items: center;
    }
    
    .site-header__actions .button--secondary { 
      display: none; 
    }

    .site-header__actions .header-demo-link {
      padding: 0.4rem 0.75rem;
      font-size: 0.85rem;
      min-height: 32px;
    }

    .site-header__actions .header-demo-link::before {
      content: 'Demo';
    }

    .site-header__actions .header-demo-link span {
      display: none;
    }
  }
</style>

<script is:inline>
  const btn = document.getElementById('hamburgerBtn');
  const menu = document.getElementById('sideMenu');
  const overlay = document.getElementById('sideMenuOverlay');
  const close = document.getElementById('closeSideMenu');
  function openM() { menu.classList.add('open'); overlay.classList.add('open'); }
  function closeM() { menu.classList.remove('open'); overlay.classList.remove('open'); }
  btn?.addEventListener('click', openM);
  close?.addEventListener('click', closeM);
  overlay?.addEventListener('click', closeM);
  
  document.querySelectorAll('.side-link').forEach(function(l) { 
    l.addEventListener('click', function(e) {
      // For contact link, always go to home page contact section
      if (l.hasAttribute('data-contact-link')) {
        e.preventDefault();
        closeM();
        if (window.location.pathname === '/' || window.location.pathname === '') {
          // Already on home page, just scroll
          document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' });
        } else {
          // Navigate to home page with hash - use origin to ensure correct URL
          window.location.href = window.location.origin + '/#contact';
        }
      } else {
        closeM();
      }
    });
  });
</script>
