---
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <img src="/logo.png" alt="Kernal Automation" />
      <span>Kernal Automation — SI Dept.</span>
    </a>
    <nav class="nav">
      <a href="/#products">Training Kits</a>
      <a href="/#cabinets">Control Cabinets</a>
      <a href="/services/">Services</a>
      <a href="/faq/">FAQ</a>
      <a href="/about/">About</a>
      <a href="/#contact">Contact</a>
    </nav>
    <div style="display:flex;align-items:center;gap:0.5rem;">
      <a class="button button--secondary" href="https://wa.me/8617612051841?text=Hi%20Peggy%2C%20I%20need%20the%20latest%20PLC%20training%20kit%20catalog." target="_blank">Get Catalog</a>
      <button id="hamburgerBtn" class="hamburger-btn" aria-label="Menu" style="display:none;flex-direction:column;gap:4px;padding:8px;border:none;background:none;cursor:pointer;">
        <span style="display:block;width:20px;height:2px;background:var(--primary);border-radius:2px;"></span>
        <span style="display:block;width:20px;height:2px;background:var(--primary);border-radius:2px;"></span>
        <span style="display:block;width:20px;height:2px;background:var(--primary);border-radius:2px;"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile side menu -->
<div id="sideMenu" style="position:fixed;inset:0 0 0 auto;z-index:1100;width:280px;background:#fff;box-shadow:-4px 0 24px rgba(0,0,0,0.15);transform:translateX(100%);transition:transform 0.3s ease;">
  <div style="display:flex;flex-direction:column;height:100%;padding:1.25rem;overflow-y:auto;">
    <button id="closeSideMenu" style="align-self:flex-end;border:none;background:none;font-size:1.5rem;cursor:pointer;color:var(--text-light);">&times;</button>
    <p style="font-size:0.72rem;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:0.08em;margin:1rem 0 0.5rem;">Navigation</p>
    <nav style="display:flex;flex-direction:column;gap:0.25rem;margin-bottom:1.5rem;">
      <a class="side-link" href="/#products" style="padding:0.5rem 0;font-size:0.92rem;font-weight:500;">Training Kits</a>
      <a class="side-link" href="/#cabinets" style="padding:0.5rem 0;font-size:0.92rem;font-weight:500;">Control Cabinets</a>
      <a class="side-link" href="/services/" style="padding:0.5rem 0;font-size:0.92rem;font-weight:500;">Services</a>
      <a class="side-link" href="/faq/" style="padding:0.5rem 0;font-size:0.92rem;font-weight:500;">FAQ</a>
      <a class="side-link" href="/about/" style="padding:0.5rem 0;font-size:0.92rem;font-weight:500;">About</a>
      <a class="side-link" href="/#contact" style="padding:0.5rem 0;font-size:0.92rem;font-weight:500;">Contact</a>
    </nav>
    <div style="margin-top:auto;border-top:1px solid var(--border);padding-top:1rem;display:flex;flex-direction:column;gap:0.5rem;font-size:0.88rem;">
      <a href="https://wa.me/8617612051841" target="_blank" style="color:var(--whatsapp);font-weight:600;">WhatsApp Peggy</a>
      <a href="mailto:peggy@kernal-automation.com" style="color:var(--text-light);">peggy@kernal-automation.com</a>
    </div>
  </div>
</div>
<div id="sideMenuOverlay" style="position:fixed;inset:0;z-index:1050;background:rgba(0,0,0,0.4);display:none;"></div>

<style>
  @media (max-width: 768px) {
    .hamburger-btn { display: flex !important; }
  }
</style>

<script is:inline>
  const btn = document.getElementById('hamburgerBtn');
  const menu = document.getElementById('sideMenu');
  const overlay = document.getElementById('sideMenuOverlay');
  const close = document.getElementById('closeSideMenu');
  function openM() { menu.style.transform='translateX(0)'; overlay.style.display='block'; }
  function closeM() { menu.style.transform='translateX(100%)'; overlay.style.display='none'; }
  btn?.addEventListener('click', openM);
  close?.addEventListener('click', closeM);
  overlay?.addEventListener('click', closeM);
  document.querySelectorAll('.side-link').forEach(function(l) { l.addEventListener('click', closeM); });
</script>
